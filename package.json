{
  "name": "jsda-kit",
  "version": "1.3.9",
  "access": "public",
  "description": "JSDA Toolkit for modern Web",
  "keywords": [
    "JSDA",
    "JS",
    "JAMStack",
    "SSR",
    "SSG",
    "Micro-products",
    "Symbiote.js",
    "JSDA-Kit"
  ],
  "homepage": "https://github.com/rnd-pro/jsda-kit#readme",
  "bugs": {
    "url": "https://github.com/rnd-pro/jsda-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rnd-pro/jsda-kit.git"
  },
  "license": "MIT",
  "author": "team@rnd-pro.com",
  "type": "module",
  "main": "iso/index.js",
  "exports": {
    ".": {
      "types": "./types/jsda.d.ts",
      "default": "./iso/index.js"
    },
    "./server": "./server/index.js",
    "./node": "./node/index.js",
    "./browser": "./browser/index.js",
    "./cfg": "./cfg/CFG.js",
    "./*": "./*"
  },
  "bin": {
    "jsda": "./cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "jsda-ssg": "node ./node/watch.js",
    "jsda-serve": "node ./server/index.js",
    "test": "node --test test/node/**/*.test.js test/iso/**/*.test.js test/server/**/*.test.js && npx playwright test",
    "test:unit": "node --test test/node/**/*.test.js test/iso/**/*.test.js",
    "test:server": "node --test test/server/**/*.test.js",
    "test:browser": "npx playwright test",
    "types": "npx -y -p typescript tsc",
    "pub": "npm run types && npm test && npm publish"
  },
  "dependencies": {
    "@minify-html/node": "^0.16.4",
    "@symbiotejs/symbiote": "^3.5.8",
    "esbuild": "^0.25.9",
    "esbuild-minify-templates": "^0.11.0",
    "highlight.js": "^11.11.1",
    "linkedom": ">=0.16.0",
    "marked": "^16.2.1",
    "marked-highlight": "^2.2.2",
    "@types/node": "^24.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  },
  "types": "./types/jsda.d.ts"
}