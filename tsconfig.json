{
  "compilerOptions": {
    "pretty": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
        "ESNext",
        "ESNext.Array",
        "DOM",
        "DOM.Iterable",
        "WebWorker"
      ],
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 2,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "**/*.js",
    "project.cfg.js",
    "types/"
  ],
  "exclude": [
    "node_modules",
    "cli/scaffolds/project/"
  ]
}